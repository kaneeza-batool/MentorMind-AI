# ── Required ─────────────────────────────────────────────────────
# Get a free API key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Optional: AI model ────────────────────────────────────────────
# Default: llama-3.3-70b-versatile (fast, free-tier friendly)
GROQ_MODEL=llama-3.3-70b-versatile

# ── Optional: Database ────────────────────────────────────────────
# SQLite path. Created automatically on first run.
# Docker: override to /app/data/mentormind.db (set in docker-compose.yml)
DB_PATH=data/mentormind.db

# ── Optional: CORS ────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173

# ── Optional: Timeouts ────────────────────────────────────────────
AI_TIMEOUT_SECONDS=60
URL_VALIDATE_TIMEOUT=4

# ── Optional: Feature flags ───────────────────────────────────────
# Set to true to enable live HTTP HEAD checks on AI-generated resource URLs
VALIDATE_RESOURCE_URLS=false

# ── Optional: Logging ─────────────────────────────────────────────
LOG_LEVEL=INFO
